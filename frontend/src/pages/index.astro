---
import Layout from '../layouts/Layout.astro';
import StatCard from '../components/StatCard.astro';
import CriticalList from '../components/CriticalList.astro';
import RouteList from '../components/RouteList.astro';
import ReportList from '../components/ReportList.astro';
---

<Layout title="Dashboard">
  <div class="h-app overflow-y-auto bg-eco-bg">

    <!-- Header -->
    <header class="sticky top-0 z-20 bg-eco-bg-header border-b border-eco-border backdrop-blur-sm px-6 py-3 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 rounded-lg bg-eco-green-dim flex items-center justify-center">
          <svg class="w-4 h-4 text-eco-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
          </svg>
        </div>
        <div>
          <span class="font-semibold text-eco-text-primary text-sm">EcoRuta</span>
          <span class="text-eco-text-muted text-xs ml-2 hidden sm:inline">/ Panel de administración</span>
        </div>
      </div>
      <div class="flex items-center gap-4">
        <span class="mono text-xs text-eco-text-muted hidden sm:block" id="clock">--:--:--</span>
        <div class="flex items-center gap-2">
          <span class="live-dot w-2 h-2 rounded-full bg-eco-green"></span>
          <span class="text-xs text-eco-green font-medium">EN VIVO</span>
        </div>
      </div>
    </header>

    <main class="max-w-6xl mx-auto px-4 sm:px-6 py-6 flex flex-col gap-6">

      <!-- Título sección -->
      <div class="flex items-end justify-between">
        <div>
          <p class="mono text-xs text-eco-text-muted uppercase tracking-widest mb-1">Sistema de monitoreo</p>
          <h1 class="text-2xl font-semibold text-eco-text-primary">Estado operativo <span class="text-eco-green">CDMX</span></h1>
        </div>
        <p class="mono text-xs text-eco-text-muted hidden sm:block" id="last-update">Actualizando...</p>
      </div>

      <!-- Fila 1: métricas del sistema -->
      <section class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        <div id="card-total" class="card p-5 flex flex-col gap-3 animate-fade-up">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-eco-text-muted"></span>
              <span class="text-xs font-medium text-eco-text-secondary uppercase tracking-widest">Contenedores</span>
            </div>
          </div>
          <span class="mono text-3xl font-medium text-eco-text-primary" id="val-total">—</span>
          <div class="border-t border-eco-border pt-3">
            <span class="text-xs text-eco-text-muted" id="sub-total">3 zonas CDMX</span>
          </div>
        </div>

        <div class="card p-5 flex flex-col gap-3 animate-fade-up glow-danger" style="animation-delay:0.05s">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-eco-danger"></span>
              <span class="text-xs font-medium text-eco-text-secondary uppercase tracking-widest">Críticos</span>
            </div>
            <svg class="w-3.5 h-3.5 text-eco-danger" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
            </svg>
          </div>
          <span class="mono text-3xl font-medium text-eco-danger" id="val-critical">—</span>
          <div class="border-t border-eco-border pt-3">
            <span class="text-xs text-eco-text-muted">umbral ≥80%</span>
          </div>
        </div>

        <div class="card p-5 flex flex-col gap-3 animate-fade-up glow-warning" style="animation-delay:0.10s">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-eco-warning"></span>
              <span class="text-xs font-medium text-eco-text-secondary uppercase tracking-widest">Llenos en 24h</span>
            </div>
            <svg class="w-3.5 h-3.5 text-eco-warning" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <span class="mono text-3xl font-medium text-eco-warning" id="val-predicted">—</span>
          <div class="border-t border-eco-border pt-3">
            <span class="text-xs text-eco-text-muted">predicción IA</span>
          </div>
        </div>

        <div class="card p-5 flex flex-col gap-3 animate-fade-up glow-green" style="animation-delay:0.15s">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-eco-green"></span>
              <span class="text-xs font-medium text-eco-text-secondary uppercase tracking-widest">Recolectores</span>
            </div>
            <svg class="w-3.5 h-3.5 text-eco-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <span class="mono text-3xl font-medium text-eco-green" id="val-collectors">—</span>
          <div class="border-t border-eco-border pt-3">
            <span class="text-xs text-eco-text-muted" id="sub-collectors">activos hoy</span>
          </div>
        </div>
      </section>

      <!-- Fila 2: métricas de impacto -->
      <section>
        <p class="mono text-xs text-eco-text-muted uppercase tracking-widest mb-3">Impacto operativo</p>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
          <StatCard id="card-km" label="Km ahorrados" value="—" sub="vs ruta estándar" color="info"
            icon="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
          <StatCard id="card-co2" label="CO₂ evitado" value="—" sub="kg por operación" color="success"
            icon="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064"/>
          <StatCard id="card-savings" label="Ahorro diario" value="—" sub="MXN combustible" color="success"
            icon="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          <StatCard id="card-reduction" label="Reducción ruta" value="—" sub="eficiencia IA" color="info"
            icon="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
        </div>
      </section>

      <!-- Mapa + Críticos -->
      <section class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="card p-5 flex flex-col gap-4">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-eco-info"></span>
              <h2 class="text-xs font-medium text-eco-text-secondary uppercase tracking-widest">Mapa en tiempo real</h2>
            </div>
            <span class="mono text-xs text-eco-text-muted" id="map-count">— puntos</span>
          </div>
          <div id="map" class="w-full h-64 rounded-lg overflow-hidden z-0"></div>
          <div class="flex gap-4">
            <span class="flex items-center gap-1.5 text-xs text-eco-text-muted">
              <span class="w-2 h-2 rounded-full bg-eco-danger"></span>Crítico
            </span>
            <span class="flex items-center gap-1.5 text-xs text-eco-text-muted">
              <span class="w-2 h-2 rounded-full bg-eco-warning"></span>Medio
            </span>
            <span class="flex items-center gap-1.5 text-xs text-eco-text-muted">
              <span class="w-2 h-2 rounded-full bg-eco-green"></span>Normal
            </span>
          </div>
        </div>
        <CriticalList />
      </section>

      <!-- Predicciones IA -->
      <section class="card p-5 flex flex-col gap-4">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-eco-warning"></span>
            <h2 class="text-xs font-medium text-eco-text-secondary uppercase tracking-widest">Predicciones IA — próximas 24h</h2>
          </div>
          <span id="model-badge" class="mono text-xs bg-eco-green-dim text-eco-green px-2 py-0.5 rounded-md">Modelo cargando...</span>
        </div>
        <ul id="prediction-list" class="grid grid-cols-1 sm:grid-cols-2 gap-2">
          <li class="text-xs text-eco-text-muted">Cargando predicciones...</li>
        </ul>
      </section>

      <!-- Rutas + Reportes -->
      <section class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <RouteList />
        <ReportList />
      </section>

      <!-- Zonas -->
      <section class="card p-5 flex flex-col gap-4">
        <div class="flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-eco-text-muted"></span>
          <h2 class="text-xs font-medium text-eco-text-secondary uppercase tracking-widest">Desglose por zona</h2>
        </div>
        <div id="zone-list" class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          <p class="text-xs text-eco-text-muted">Cargando...</p>
        </div>
      </section>

    </main>
  </div>
</Layout>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<style>
  .leaflet-container { background: #080c0a !important; }
  .leaflet-tile { filter: brightness(0.3) saturate(0.4) hue-rotate(100deg); }
  .leaflet-control-zoom a { background: #131a14 !important; color: #6b7f6e !important; border-color: #1c261e !important; }
  .leaflet-popup-content-wrapper { background: #131a14; border: 1px solid #2a3d2c; color: #e8f0ea; border-radius: 8px; }
  .leaflet-popup-tip { background: #131a14; }
</style>

<script>
  const API = 'http://localhost:8000';

  // Reloj
  function updateClock() {
    const el = document.getElementById('clock');
    if (el) el.textContent = new Date().toLocaleTimeString('es-MX', { hour12: false });
  }
  updateClock();
  setInterval(updateClock, 1000);

  // ── Mapa ────────────────────────────────────────────────────────
  import L from 'https://unpkg.com/leaflet@1.9.4/dist/leaflet-src.esm.js';

  const map = L.map('map', { zoomControl: true }).setView([19.432, -99.133], 12);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© OpenStreetMap', maxZoom: 18,
  }).addTo(map);

  const markers: any[] = [];

  function markerColor(fill: number) {
    if (fill >= 0.8) return '#f87171';
    if (fill >= 0.5) return '#fbbf24';
    return '#22c55e';
  }

  function circleIcon(color: string) {
    return L.divIcon({
      className: '',
      html: `<div style="width:10px;height:10px;border-radius:50%;background:${color};border:1.5px solid rgba(255,255,255,0.2);box-shadow:0 0 8px ${color}88"></div>`,
      iconSize: [10, 10], iconAnchor: [5, 5],
    });
  }

  async function loadMap() {
    try {
      const res = await fetch(`${API}/api/v1/containers/readings`);
      const containers: any[] = await res.json();
      markers.forEach(m => m.remove());
      markers.length = 0;
      containers.forEach(c => {
        const color = markerColor(c.fill_level);
        const m = L.marker([c.latitude, c.longitude], { icon: circleIcon(color) })
          .bindPopup(`<b style="color:#e8f0ea">${c.container_id}</b><br/><span style="color:#6b7f6e">Zona: ${c.zone}</span><br/><span style="color:${color}">${Math.round(c.fill_level * 100)}%</span>`)
          .addTo(map);
        markers.push(m);
      });
      const mc = document.getElementById('map-count');
      if (mc) mc.textContent = `${containers.length} puntos`;
    } catch {}
  }

  loadMap();
  setInterval(loadMap, 10_000);

  // ── Métricas ─────────────────────────────────────────────────────
  function setText(id: string, val: any) {
    const el = document.getElementById(id);
    if (el) el.textContent = String(val ?? '—');
  }

  function setCardValue(id: string, val: any) {
    const el = document.querySelector(`#${id} .mono`);
    if (el) el.textContent = String(val ?? '—');
  }

  async function loadMetrics() {
    try {
      const res = await fetch(`${API}/api/v1/metrics/`);
      const d = await res.json();

      setText('val-total', d.system.total_containers_monitored);
      setText('sub-total', `${d.system.total_sensors_registered} sensores`);
      setText('val-critical', d.system.containers_critical);
      setText('val-predicted', d.system.containers_predicted_full_24h);
      setText('val-collectors', d.system.active_collectors);
      setText('sub-collectors', `de ${d.system.total_collectors} totales`);

      setCardValue('card-km', `${d.efficiency.distance_saved_km} km`);
      setCardValue('card-co2', `${d.environmental.co2_avoided_kg} kg`);
      setCardValue('card-savings', `$${d.financial.daily_fuel_savings_mxn}`);
      setCardValue('card-reduction', `${d.efficiency.distance_reduction_pct}%`);

      loadZones(d.zones);

      const lu = document.getElementById('last-update');
      if (lu) lu.textContent = `Última actualización: ${new Date().toLocaleTimeString('es-MX')}`;
    } catch {}
  }

  function loadZones(zones: any[]) {
    const el = document.getElementById('zone-list');
    if (!el || !zones?.length) return;
    el.innerHTML = zones.map((z, i) => {
      const pct = Math.round(z.avg_fill_level * 100);
      const bar = pct >= 80 ? 'bg-eco-danger' : pct >= 50 ? 'bg-eco-warning' : 'bg-eco-green';
      const color = pct >= 80 ? 'text-eco-danger' : pct >= 50 ? 'text-eco-warning' : 'text-eco-green';
      return `
        <div class="bg-eco-bg-header border border-eco-border rounded-xl p-4 flex flex-col gap-3 animate-fade-up" style="animation-delay:${i * 0.08}s">
          <div class="flex items-center justify-between">
            <span class="text-sm font-medium text-eco-text-primary capitalize">${z.zone}</span>
            <span class="mono text-xs ${color}">${z.critical_containers} críticos</span>
          </div>
          <div class="h-1 bg-eco-border rounded-full overflow-hidden">
            <div class="${bar} h-full rounded-full transition-all duration-700" style="width:${pct}%"></div>
          </div>
          <div class="flex justify-between">
            <span class="mono text-xs text-eco-text-muted">${z.total_containers} contenedores</span>
            <span class="mono text-xs ${color}">${pct}%</span>
          </div>
        </div>`;
    }).join('');
  }

  loadMetrics();
  setInterval(loadMetrics, 15_000);

  // ── Predicciones ─────────────────────────────────────────────────
  async function loadPredictions() {
    const list = document.getElementById('prediction-list')!;
    const badge = document.getElementById('model-badge')!;
    try {
      const res = await fetch(`${API}/api/v1/predictions/`);
      if (!res.ok) {
        badge.textContent = 'Modelo entrenando...';
        badge.className = 'mono text-xs bg-eco-warning-dim text-eco-warning px-2 py-0.5 rounded-md';
        list.innerHTML = '<li class="text-xs text-eco-text-muted col-span-2">El modelo IA está entrenando con datos del simulador. Disponible en unos momentos.</li>';
        return;
      }
      const data = await res.json();
      const preds: any[] = data.predictions ?? [];
      badge.textContent = `Modelo activo · ${preds.length} predicciones`;

      const urgent = preds.filter(p => p.estimated_hours_to_full !== null && p.estimated_hours_to_full <= 24);
      if (!urgent.length) {
        list.innerHTML = '<li class="text-xs text-eco-text-muted col-span-2">Sin contenedores urgentes en las próximas 24h.</li>';
        return;
      }

      list.innerHTML = urgent.slice(0, 8).map((p, i) => {
        const hrs = p.estimated_hours_to_full?.toFixed(1) ?? '?';
        const now = Math.round(p.current_fill_level * 100);
        const pred = Math.round(p.predicted_fill_24h * 100);
        const confColor = p.confidence === 'high' ? 'text-eco-danger' : p.confidence === 'medium' ? 'text-eco-warning' : 'text-eco-text-muted';
        const hrsColor = Number(hrs) <= 6 ? 'text-eco-danger' : Number(hrs) <= 12 ? 'text-eco-warning' : 'text-eco-info';
        return `
          <li class="flex items-center justify-between rounded-lg bg-eco-bg-header border border-eco-border px-4 py-3 gap-3 animate-fade-up" style="animation-delay:${i * 0.05}s">
            <div class="min-w-0">
              <p class="mono text-sm font-medium text-eco-text-primary">${p.container_id}</p>
              <p class="text-xs text-eco-text-muted mt-0.5 capitalize">${p.zone} · ${now}% → ${pred}%</p>
            </div>
            <div class="text-right shrink-0">
              <p class="mono text-sm font-medium ${hrsColor}">${hrs}h</p>
              <p class="mono text-xs ${confColor}">${p.confidence}</p>
            </div>
          </li>`;
      }).join('');
    } catch {}
  }

  loadPredictions();
  setInterval(loadPredictions, 20_000);
</script>