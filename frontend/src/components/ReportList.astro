---
<div class="card p-5 flex flex-col gap-4">
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-2">
      <span class="w-1.5 h-1.5 rounded-full bg-eco-warning"></span>
      <h2 class="text-xs font-medium text-eco-text-secondary uppercase tracking-widest">Reportes ciudadanos</h2>
    </div>
    <span id="report-count" class="mono text-xs text-eco-warning bg-eco-warning-dim px-2 py-0.5 rounded-md">—</span>
  </div>
  <ul id="report-list" class="flex flex-col gap-2">
    <li class="text-xs text-eco-text-muted">Cargando...</li>
  </ul>
</div>

<script>
  async function load() {
    const list = document.getElementById('report-list')!;
    const count = document.getElementById('report-count')!;
    try {
      const res = await fetch('http://localhost:8000/api/v1/reports/citizen');
      const data: any[] = await res.json();
      count.textContent = String(data.length);

      if (!data.length) {
        list.innerHTML = '<li class="text-xs text-eco-text-muted">Sin reportes por el momento.</li>';
        return;
      }

      list.innerHTML = [...data].reverse().slice(0, 5).map((r, i) => `
        <li class="rounded-lg bg-eco-bg-header border border-eco-border px-4 py-3 animate-fade-up" style="animation-delay:${i * 0.06}s">
          <p class="text-sm text-eco-text-primary">${r.description}</p>
          <p class="mono text-xs text-eco-text-muted mt-1 capitalize">${r.zone} · ${r.latitude.toFixed(4)}, ${r.longitude.toFixed(4)}</p>
        </li>`).join('');
    } catch {
      list.innerHTML = '<li class="text-xs text-eco-danger">Error al cargar reportes</li>';
    }
  }

  load();
  setInterval(load, 15_000);
</script>