---
---
<div class="card p-5 flex flex-col gap-4">
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-2">
      <span class="w-1.5 h-1.5 rounded-full bg-eco-danger"></span>
      <h2 class="text-xs font-medium text-eco-text-secondary uppercase tracking-widest">Contenedores críticos</h2>
    </div>
    <span id="critical-count" class="mono text-xs text-eco-danger bg-eco-danger-dim px-2 py-0.5 rounded-md">—</span>
  </div>
  <ul id="critical-list" class="flex flex-col gap-2">
    <li class="text-xs text-eco-text-muted">Cargando...</li>
  </ul>
</div>

<script>
  const ZONE_COLORS: Record<string, string> = {
    centro: 'text-eco-info bg-eco-info-dim',
    norte:  'text-eco-warning bg-eco-warning-dim',
    sur:    'text-eco-green bg-eco-green-dim',
  };

  async function load() {
    const list = document.getElementById('critical-list')!;
    const count = document.getElementById('critical-count')!;
    try {
      const res = await fetch('http://localhost:8000/api/v1/containers/critical?threshold=0.8');
      const data = await res.json();
      const containers: any[] = data.containers ?? [];
      count.textContent = String(containers.length);

      if (!containers.length) {
        list.innerHTML = '<li class="text-xs text-eco-text-muted">Sin contenedores críticos</li>';
        return;
      }

      list.innerHTML = containers
        .sort((a, b) => b.fill_level - a.fill_level)
        .slice(0, 6)
        .map(c => {
          const pct = Math.round(c.fill_level * 100);
          const bar = pct >= 90 ? 'bg-eco-danger' : 'bg-eco-warning';
          const zc = ZONE_COLORS[c.zone] ?? 'text-eco-text-secondary bg-eco-bg-panel';
          return `
            <li class="flex items-center gap-3">
              <span class="mono text-xs font-medium text-eco-text-primary w-20 shrink-0">${c.container_id}</span>
              <div class="flex-1 h-1 bg-eco-border rounded-full overflow-hidden">
                <div class="${bar} h-full rounded-full" style="width:${pct}%;animation:bar-fill 0.8s ease"></div>
              </div>
              <span class="mono text-xs text-eco-text-secondary w-9 text-right shrink-0">${pct}%</span>
              <span class="text-xs px-2 py-0.5 rounded-md shrink-0 ${zc}">${c.zone}</span>
            </li>`;
        }).join('');
    } catch {
      list.innerHTML = '<li class="text-xs text-eco-danger">Error al cargar</li>';
    }
  }

  load();
  setInterval(load, 10_000);
</script>